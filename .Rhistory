# -----------------------------------------------------------
# Carregar bibliotecas
# -----------------------------------------------------------
library(sf)       # manipulação de dados espaciais
library(ggplot2)  # visualização
library(leaflet)  # mapa interativo
# -----------------------------------------------------------
# 1. Ler tabela de ocorrências
# -----------------------------------------------------------
dados <- read.delim("ocorrencias_stryphnodendron_confertum.txt")
# -----------------------------------------------------------
# Carregar bibliotecas
# -----------------------------------------------------------
library(sf)       # manipulação de dados espaciais
library(ggplot2)  # visualização
library(leaflet)  # mapa interativo
# -----------------------------------------------------------
# 1. Ler tabela de ocorrências
# -----------------------------------------------------------
dados <- read.delim("data/ocorrencias_stryphnodendron_confertum.txt")
# A tabela deve ter colunas:
# lon = longitude
# lat = latitude
# -----------------------------------------------------------
# 2. Remover coordenadas duplicadas
# -----------------------------------------------------------
# Remove linhas com mesma latitude e longitude
dados <- unique(dados[, c("lon","lat")])
# Outra forma possível seria:
# dados <- dados[!duplicated(dados[,c("lon","lat")]), ]
# -----------------------------------------------------------
# 3. Converter tabela para objeto espacial
# -----------------------------------------------------------
# EPSG 4326 = sistema geográfico baseado no datum WGS84
# unidade = graus (latitude/longitude)
sp_points <- st_as_sf(
dados,
coords = c("lon","lat"),
crs = 4326
)
# -----------------------------------------------------------
# 4. Detectar possíveis outliers espaciais
# -----------------------------------------------------------
# Transformar para UTM para medir distâncias corretamente
# Zona 23S cobre grande parte do Brasil central
sp_points_utm <- st_transform(sp_points, 32723)
# Calcular centróide da distribuição
centro <- st_centroid(st_union(sp_points_utm))
# Distância de cada ponto ao centróide
distancias <- st_distance(sp_points_utm, centro)
# Converter para km
dist_km <- as.numeric(distancias) / 1000
# Limite de outlier = média + 3 desvios padrão
limite <- mean(dist_km) + 3*sd(dist_km)
# identificar outliers
outliers <- dist_km > limite
# separar pontos normais e outliers
sp_points_clean <- sp_points_utm[!outliers, ]
sp_points_outliers <- sp_points_utm[outliers, ]
# -----------------------------------------------------------
# 5. Calcular EOO (Extent of Occurrence)
# -----------------------------------------------------------
# Convex hull com pontos SEM outliers
hull <- st_convex_hull(
st_union(
st_combine(sp_points_clean)
)
)
# área em km2
eoo_km2 <- st_area(hull) / 1e6
print(eoo_km2)
# -----------------------------------------------------------
# 6. Visualização simples (base R)
# -----------------------------------------------------------
#plot(st_geometry(hull), col="lightblue")
#plot(st_geometry(sp_points_clean), add=TRUE, pch=16)
#plot(st_geometry(sp_points_outliers), add=TRUE, col="red", pch=17)
# -----------------------------------------------------------
# 7. Visualização com ggplot
# -----------------------------------------------------------
ggplot() +
geom_sf(data = hull, fill = "lightblue", color = "blue", alpha = 0.4) +
geom_sf(data = sp_points_clean, color = "darkgreen", size = 1) +
geom_sf(data = sp_points_outliers, color = "red", size = 3) +
scale_x_continuous(n.breaks = 2, labels = function(x) paste0(round(x,2),"°W")) +
scale_y_continuous(n.breaks = 2, labels = function(y) paste0(round(y,2),"°S")) +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
expand_limits(x = c(min(dados$lon) - 0.1,
max(dados$lon) + 0.1)) + labs(x = NULL, y = NULL) +
labs(x = "Longitude", y = "Latitude") +
labs(title = "Distribuição de Stryphnodendron confertum") +
theme(plot.title = element_text(size = 8))
# -----------------------------------------------------------
# 8. Mapa interativo sem "outliers"
# -----------------------------------------------------------
# Calcular centróide da distribuição
centro_coords_geograficas <- st_centroid(st_union(sp_points))
# Distância de cada ponto ao centróide
distancias_coords_geograficas <- st_distance(sp_points, centro_coords_geograficas)
# Converter para km
dist_km_coords_geograficas <- as.numeric(distancias_coords_geograficas) / 1000
limite_coords_geograficas <- mean(dist_km_coords_geograficas) + 3*sd(dist_km_coords_geograficas)
# identificar outliers
outliers_coords_geograficas <- dist_km_coords_geograficas > limite_coords_geograficas
# separar pontos normais e outliers
sp_points_clean_coords_geograficas <- sp_points[!outliers_coords_geograficas, ]
sp_points_outliers <- sp_points_clean_coords_geograficas[outliers_coords_geograficas, ]
hull_coords_geograficas <- st_convex_hull(
st_union(
st_combine(sp_points_clean_coords_geograficas)
)
)
leaflet() |>
addTiles() |>
addPolygons(data = hull_coords_geograficas, color="blue", fillOpacity = 0.3) |>
addCircleMarkers(data = sp_points_clean_coords_geograficas, radius = 2, color = "green") |>
addCircleMarkers(data = sp_points_outliers, radius = 5, color = "red")
# -----------------------------------------------------------
# Carregar bibliotecas
# -----------------------------------------------------------
library(sf)       # manipulação de dados espaciais
library(ggplot2)  # visualização
library(leaflet)  # mapa interativo
# -----------------------------------------------------------
# 1. Ler tabela de ocorrências
# -----------------------------------------------------------
dados <- read.delim("../data/ocorrencias_stryphnodendron_confertum.txt")
# -----------------------------------------------------------
# Carregar bibliotecas
# -----------------------------------------------------------
library(sf)       # manipulação de dados espaciais
library(ggplot2)  # visualização
library(leaflet)  # mapa interativo
# -----------------------------------------------------------
# 1. Ler tabela de ocorrências
# -----------------------------------------------------------
dados <- read.delim("data/ocorrencias_stryphnodendron_confertum.txt")
# A tabela deve ter colunas:
# lon = longitude
# lat = latitude
# -----------------------------------------------------------
# 2. Remover coordenadas duplicadas
# -----------------------------------------------------------
# Remove linhas com mesma latitude e longitude
dados <- unique(dados[, c("lon","lat")])
# Outra forma possível seria:
# dados <- dados[!duplicated(dados[,c("lon","lat")]), ]
# -----------------------------------------------------------
# 3. Converter tabela para objeto espacial
# -----------------------------------------------------------
# EPSG 4326 = sistema geográfico baseado no datum WGS84
# unidade = graus (latitude/longitude)
sp_points <- st_as_sf(
dados,
coords = c("lon","lat"),
crs = 4326
)
# -----------------------------------------------------------
# 4. Detectar possíveis outliers espaciais
# -----------------------------------------------------------
# Transformar para UTM para medir distâncias corretamente
# Zona 23S cobre grande parte do Brasil central
sp_points_utm <- st_transform(sp_points, 32723)
# Calcular centróide da distribuição
centro <- st_centroid(st_union(sp_points_utm))
# Distância de cada ponto ao centróide
distancias <- st_distance(sp_points_utm, centro)
# Converter para km
dist_km <- as.numeric(distancias) / 1000
# Limite de outlier = média + 3 desvios padrão
limite <- mean(dist_km) + 3*sd(dist_km)
# identificar outliers
outliers <- dist_km > limite
# separar pontos normais e outliers
sp_points_clean <- sp_points_utm[!outliers, ]
sp_points_outliers <- sp_points_utm[outliers, ]
# -----------------------------------------------------------
# 5. Calcular EOO (Extent of Occurrence)
# -----------------------------------------------------------
# Convex hull com pontos SEM outliers
hull <- st_convex_hull(
st_union(
st_combine(sp_points_clean)
)
)
# área em km2
eoo_km2 <- st_area(hull) / 1e6
print(eoo_km2)
# -----------------------------------------------------------
# 6. Visualização simples (base R)
# -----------------------------------------------------------
#plot(st_geometry(hull), col="lightblue")
#plot(st_geometry(sp_points_clean), add=TRUE, pch=16)
#plot(st_geometry(sp_points_outliers), add=TRUE, col="red", pch=17)
# -----------------------------------------------------------
# 7. Visualização com ggplot
# -----------------------------------------------------------
ggplot() +
geom_sf(data = hull, fill = "lightblue", color = "blue", alpha = 0.4) +
geom_sf(data = sp_points_clean, color = "darkgreen", size = 1) +
geom_sf(data = sp_points_outliers, color = "red", size = 3) +
scale_x_continuous(n.breaks = 2, labels = function(x) paste0(round(x,2),"°W")) +
scale_y_continuous(n.breaks = 2, labels = function(y) paste0(round(y,2),"°S")) +
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
expand_limits(x = c(min(dados$lon) - 0.1,
max(dados$lon) + 0.1)) + labs(x = NULL, y = NULL) +
labs(x = "Longitude", y = "Latitude") +
labs(title = "Distribuição de Stryphnodendron confertum") +
theme(plot.title = element_text(size = 8))
# -----------------------------------------------------------
# 8. Mapa interativo sem "outliers"
# -----------------------------------------------------------
# Calcular centróide da distribuição
centro_coords_geograficas <- st_centroid(st_union(sp_points))
# Distância de cada ponto ao centróide
distancias_coords_geograficas <- st_distance(sp_points, centro_coords_geograficas)
# Converter para km
dist_km_coords_geograficas <- as.numeric(distancias_coords_geograficas) / 1000
limite_coords_geograficas <- mean(dist_km_coords_geograficas) + 3*sd(dist_km_coords_geograficas)
# identificar outliers
outliers_coords_geograficas <- dist_km_coords_geograficas > limite_coords_geograficas
# separar pontos normais e outliers
sp_points_clean_coords_geograficas <- sp_points[!outliers_coords_geograficas, ]
sp_points_outliers <- sp_points_clean_coords_geograficas[outliers_coords_geograficas, ]
hull_coords_geograficas <- st_convex_hull(
st_union(
st_combine(sp_points_clean_coords_geograficas)
)
)
leaflet() |>
addTiles() |>
addPolygons(data = hull_coords_geograficas, color="blue", fillOpacity = 0.3) |>
addCircleMarkers(data = sp_points_clean_coords_geograficas, radius = 2, color = "green") |>
addCircleMarkers(data = sp_points_outliers, radius = 5, color = "red")
