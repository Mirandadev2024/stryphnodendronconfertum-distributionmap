#  coord_fixed() + theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
#  scale_x_continuous(n.breaks = 4) +
#  theme_minimal()
ggplot() +
geom_sf(data = hull, fill = "lightblue", color = "blue", alpha = 0.4) +
geom_sf(data = sp_points_clean, color = "darkgreen", size = 2) +
geom_sf(data = sp_points_outliers, color = "red", size = 3) +
scale_x_continuous(n.breaks = 2) +
scale_x_continuous(labels = function(x) paste0(round(x,2),"°W"))
theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
theme_minimal()
